generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SystemUser {
  id            Int                      @id @default(autoincrement())
  userName      String                   @map("user_name") @db.VarChar
  nsoEmployeeId String?                  @map("nso_employee_id") @db.Char(6)
  statusId      String                   @map("status_id") @db.Char(1)
  needSync      String?                  @map("need_sync") @db.Char(1)
  password      String?
  logging       Logging[]
  status        Status                   @relation(fields: [statusId], references: [id], onUpdate: Restrict, map: "FK_2084")
  nsoEmployee   NsoEmployee?             @relation(fields: [nsoEmployeeId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_539")
  roles         SystemUserRoleMatching[]

  @@index([statusId], map: "fkIdx_2084")
  @@index([nsoEmployeeId], map: "fkIdx_539")
  @@map("system_user")
}

model SystemRole {
  id            String                   @id(map: "PK_system_role") @db.Char(3)
  nameEng       String                   @map("name_eng") @db.VarChar
  nameLao       String                   @map("name_lao") @db.VarChar
  needSync      String?                  @map("need_sync") @db.Char(1)
  notifications Notification[]
  users         SystemUserRoleMatching[]

  @@map("system_role")
}

model SystemUserRoleMatching {
  systemRoleId String     @map("system_role_id") @db.Char(3)
  systemUserId Int        @map("system_user_id")
  needSync     String?    @map("need_sync") @db.Char(1)
  systemRole   SystemRole @relation(fields: [systemRoleId], references: [id], onUpdate: Restrict, map: "FK_1645")
  systemUser   SystemUser @relation(fields: [systemUserId], references: [id], onUpdate: Restrict, map: "FK_1648")

  @@id([systemRoleId, systemUserId], map: "PK_system_user_role_matching")
  @@index([systemRoleId], map: "fkIdx_1645")
  @@index([systemUserId], map: "fkIdx_1648")
  @@map("system_user_role_matching")
}

model Logging {
  id            Int        @default(autoincrement())
  loginTime     DateTime   @map("login_time") @db.Timestamp(6)
  logoutTime    DateTime?  @map("logout_time") @db.Timestamp(6)
  systemuser_id Int?
  needSync      String?    @map("need_sync") @db.Char(1)
  system_user   SystemUser? @relation(fields: [systemuser_id], references: [id], onUpdate: Restrict, map: "FK_536")

  @@id([id])
  @@index([systemuser_id], map: "fkIdx_536")
  @@map("logging")
}

model Status {
  id                             String                          @id(map: "PK_status") @db.VarChar(2)
  nameEng                        String                          @map("name_eng") @db.VarChar
  nameLao                        String                          @map("name_lao") @db.VarChar
  needSync                       String?                         @map("need_sync") @db.Char(1)
  accounts                       Accounts[]
  chartOfAccounts                ChartOfAccounts[]
  client                         Client[]
  clientEquitySavingArrangements ClientEquitySavingArrangement[]
  clientLoanArrangements         ClientLoanArrangement[]
  clientLoanRules                ClientLoanRule[]
  clientSavingConditions         ClientSavingCondition[]
  notifications                  Notification[]
  nso                            Nso[]
  nsoEmployees                   NsoEmployee[]
  nsoFeeModels                   NsoFeeModel[]
  nsoOffices                     NsoOffice[]
  nsoVbWsloanArrangements        NsoVbWsloanArrangement[]
  nsoVbWsloanConditions          NsoVbWsloanCondition[]
  profitDistributionRules        ProfitDistributionRule[]
  systemUsers                    SystemUser[]
  vat                            Vat[]
  vbAssetArrangements            VbAssetArrangement[]
  vbCommitteeTeams               VbCommitteeTeam[]
  vbNsoSavingArrangements        VbNsoSavingArrangement[]
  vbNsoSavingConditions          VbNsoSavingConditions[]
  villageBanks                   VillageBank[]

  @@map("status")
}

model Province {
  id         String      @id(map: "province_pk") @db.Char(2)
  nameEng    String      @map("name_eng") @db.VarChar
  nameLao    String      @map("name_lao") @db.VarChar
  needSync   String?     @map("need_sync") @db.Char(1)
  districts  District[]
  nsos       Nso[]
  nsoOffices NsoOffice[]
  vbCodes    VbCode[]
  vbCode2s   VbCode2[]

  @@map("province")
}

model District {
  id         String      @id(map: "district_pk") @db.Char(4)
  nameEng    String      @map("name_eng") @db.VarChar
  nameLao    String      @map("name_lao") @db.VarChar
  provinceId String?     @map("province_id") @db.Char(2)
  districtNo String?     @map("district_no") @db.Char(2)
  needSync   String?     @map("need_sync") @db.Char(1)
  province   Province?   @relation(fields: [provinceId], references: [id], onUpdate: Restrict, map: "FK_312")
  nsos       Nso[]
  nsoOffices NsoOffice[]
  vbCodes    VbCode[]
  vbCode2s   VbCode2[]

  @@index([provinceId], map: "fkIdx_312")
  @@map("district")
}

model Country {
  country_id   String        @id(map: "PK_countries") @db.Char(3)
  nameEng      String?       @map("name_eng") @db.VarChar
  nameLao      String?       @map("name_lao") @db.VarChar
  alpha2Code   String?       @map("alpha2code") @db.Char(2)
  alpha3Code   String?       @map("alpha3code") @db.Char(3)
  needSync     String?       @map("need_sync") @db.Char(1)
  nsos         Nso[]
  nsoEmployees NsoEmployee[]
  vats         Vat[]

  @@map("countries")
}

model EthnicGroup {
  id       String    @id(map: "PK_Ethnicgroup") @db.Char(2)
  nameEng  String    @map("name_eng") @db.VarChar
  nameLao  String    @map("name_lao") @db.VarChar
  needSync String?   @map("need_sync") @db.Char(1)
  villages Village[]

  @@map("ethnicgroup")
}

model EconomicStatus {
  id       String   @id(map: "PK_economic_status") @db.Char(1)
  nameEng  String   @map("name_eng") @db.VarChar
  nameLao  String   @map("name_lao") @db.VarChar
  needSync String?  @map("need_sync") @db.Char(1)
  clients  Client[]

  @@map("economic_status")
}

model Profession {
  id         String   @id(map: "PK_profession") @db.Char(2)
  nameLao    String   @map("name_lao") @db.VarChar
  nameEng    String   @map("name_eng") @db.VarChar
  isDropDown String   @map("is_drop_down") @db.Char(1)
  needSync   String?  @map("need_sync") @db.Char(1)
  clients    Client[]

  @@map("profession")
}

model JobTitle {
  id            String        @id(map: "PK_jobtitle") @db.Char(2)
  nameEng       String        @map("name_eng") @db.VarChar
  nameLao       String        @map("name_lao") @db.VarChar
  needSync      String?       @map("need_sync") @db.Char(1)
  nsoEmployees1 NsoEmployee[] @relation("JobTitle1")
  nsoEmployees2 NsoEmployee[] @relation("JobTitle2")

  @@map("jobtitle")
}

model CnyLakRate {
  date         DateTime  @db.Date
  yuanToLak    Decimal?  @map("yuan_to_lak") @db.Decimal(255, 0)
  vbCode       String    @map("vbcode") @db.Char(7)
  synchronized String?   @db.Char(1)
  needSync     String?   @map("need_sync") @db.Char(1)
  vb           VbCode    @relation(fields: [vbCode], references: [id], onUpdate: Restrict)

  @@id([date, vbCode])
  @@map("cny_lak_rate")
}

model Vat {
  id        BigInt    @id(map: "VAT_pkey") @default(autoincrement())
  vatRate   Decimal?  @map("vat_rate") @db.Decimal(10, 5)
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  countryId String?   @map("coutntry_id") @db.Char(3)
  statusId  String?   @map("status") @db.Char(1)
  needSync  String?   @map("need_sync") @db.Char(1)
  country   Country?  @relation(fields: [countryId], references: [country_id], onDelete: Restrict, onUpdate: Restrict, map: "vat_coutntry_id")
  status    Status?   @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "vat_status")

  @@map("vat")
}

model VbCode {
  id                                     String                          @id(map: "vbcode_pk") @db.Char(7)
  provinceId                             String                          @map("province_id") @db.Char(2)
  districtId                             String                          @map("district_id") @db.Char(4)
  villageId                              String                          @map("village_id") @db.Char(3)
  nameEng                                String                          @map("name_eng") @db.VarChar
  nameLao                                String                          @map("name_lao") @db.VarChar
  needSync                               String?                         @map("need_sync") @db.Char(1)
  vbIdOld                                String?                         @map("vb_id_old") @db.Char(7)
  accountOwners                          AccountOwner[]
  accounts                               Accounts[]
  balance                                Balance[]
  clients                                Client[]
  clientAccounts                         ClientAccount[]
  clientEquitySavingArrangements         ClientEquitySavingArrangement[]
  clientInstallmentLoanPlans             ClientInstallmentLoanPlan[]
  clientLoanArrangements                 ClientLoanArrangement[]
  clientLoanLossProvisioning             ClientLoanLossProvisioning[]
  clientLoanRules                        ClientLoanRule[]
  clientSavingArrangements               ClientSavingArrangement[]
  cnyLakRates                            CnyLakRate[]
  events                                 Events[]
  ews                                    Ews[]
  generalLedger                          GeneralLedger[]
  id_document_id_document_vbcodeTovbcode IdDocument[]                    @relation("id_document_vbcodeTovbcode")
  notifications                          Notification[]
  nsoFeeTransactions                     NsoFeeTransaction[]
  nsoShares                              NsoShares[]
  profitAndLoss                          ProfitAndLoss[]
  profitDistrVbFunds                     ProfitDistrVbFund[]
  profitDistrVbMembers                   ProfitDistrVbMember[]
  profitDistrVbReserves                  ProfitDistrVbReserve[]
  profitDistrVbcs                        ProfitDistrVbc[]
  profitDistributionArrangements         ProfitDistributionArrangement[]
  profitDistributionRules                ProfitDistributionRule[]
  transactions                           Transactions[]
  trialBalance                           TrialBalance[]
  vbAssetArrangements                    VbAssetArrangement[]
  vbFieldStaffMatchings                  VbFieldstaffMatching[]
  vbNsoSavingArrangements                VbNsoSavingArrangement[]
  vbServiceDays                          VbServiceDays[]
  vbTargets                              VbTargets[]
  district                               District                        @relation(fields: [districtId], references: [id], onUpdate: Restrict, map: "FK_1391")
  province                               Province                        @relation(fields: [provinceId], references: [id], onUpdate: Restrict, map: "FK_322")
  village_village_vbcodeTovbcode         Village?                        @relation("village_vbcodeTovbcode")
  villageBank                            VillageBank?

  @@index([districtId], map: "fkIdx_1391")
  @@index([provinceId], map: "fkIdx_322")
  @@map("vbcode")
}

model VbCode2 {
  id         String   @id(map: "vbcode_copy1_pkey") @db.Char(7)
  provinceId String   @map("province_id") @db.Char(2)
  districtId String   @map("district_id") @db.Char(4)
  villageId  String   @map("village_id") @db.Char(3)
  nameEng    String   @map("name_eng") @db.VarChar
  nameLao    String   @map("name_lao") @db.VarChar
  needSync   String?  @map("need_sync") @db.Char(1)
  vbIdOld    String?  @map("vb_id_old") @db.Char(7)
  district   District @relation(fields: [districtId], references: [id], onUpdate: Restrict, map: "vbcode_copy1_district_id_fkey")
  province   Province @relation(fields: [provinceId], references: [id], onUpdate: Restrict, map: "vbcode_copy1_province_id_fkey")

  @@index([districtId], map: "fkIdx_1391_copy1")
  @@index([provinceId], map: "fkIdx_322_copy1")
  @@map("vbcode2")
}

model VillageBank {
  vbCode                     String                   @id @map("vbcode") @db.Char(7)
  foundingDate               DateTime                 @map("foundingdate") @db.Date
  nameEng                    String                   @map("name_eng") @db.VarChar
  nameLao                    String                   @map("name_lao") @db.VarChar
  startMonthBusinessYear     Int                      @map("startmonthbusinessyear")
  monthlyMeetingDate         Int                      @map("monthlymeetingdate")
  monthlyMeetingDateDuration Int                      @map("monthlymeetingdate_duration")
  minimumSaving              Int                      @map("minimum_saving")
  maximumSaving              BigInt?                  @map("maximum_saving")
  currency                   String                   @db.Char(3)
  nsoOfficeId                String                   @map("nso_office_id") @db.Char(6)
  statusId                   String                   @map("status_id") @db.Char(1)
  equitySavingOnly           String                   @map("equity_saving_only") @db.Char(1)
  synchronized               DateTime?                @db.Timestamp(6)
  needSync                   String?                  @map("need_sync") @db.Char(1)
  vbIdOld                    String?                  @map("vb_id_old") @db.Char(7)
  exceptFee                  String?                  @map("except_fee") @db.Char(1)
  clientSavingConditions     ClientSavingCondition[]
  nsoVbWsloanArrangements    NsoVbWsloanArrangement[]
  vbCommitteeTeams           VbCommitteeTeam[]
  vb                         VbCode                   @relation(fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_1102")
  status                     Status                   @relation(fields: [statusId], references: [id], onUpdate: Restrict, map: "FK_1585")
  nsoOffice                  NsoOffice                @relation(fields: [nsoOfficeId], references: [id], onUpdate: Restrict, map: "FK_509")

  @@index([vbCode], map: "fkIdx_1102")
  @@index([statusId], map: "fkIdx_1585")
  @@index([nsoOfficeId], map: "fkIdx_509")
  @@map("villagebank")
}

model Village {
  vbCode                        String      @id @map("vbcode") @db.Char(7)
  nameEng                       String      @map("name_eng") @db.VarChar
  nameLao                       String      @map("name_lao") @db.VarChar
  ethnicGroupId                 String      @map("ethnicgroup_id") @db.Char(2)
  families                      Int?
  households                    Int?
  population                    Int?
  femalePopulation              Int?        @map("femalepopulation")
  synchronized                  DateTime?   @db.Timestamp(6)
  needSync                      String?     @map("need_sync") @db.Char(1)
  vbcode_village_vbcodeTovbcode VbCode      @relation("village_vbcodeTovbcode", fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_1225")
  ethnicGroup                   EthnicGroup @relation(fields: [ethnicGroupId], references: [id], onUpdate: Restrict, map: "FK_1336")

  @@index([vbCode], map: "fkIdx_1225")
  @@index([ethnicGroupId], map: "fkIdx_1336")
  @@map("village")
}

model VbTargets {
  businessYear       String    @map("businessyear") @db.VarChar
  membersLastYear    BigInt    @map("members_lastyear")
  membersTarget      BigInt    @map("members_target")
  savingsLastYear    BigInt    @map("savings_lastyear")
  savingsTarget      BigInt    @map("savings_target")
  loansLastYear      BigInt    @map("loans_lastyear")
  loansTarget        BigInt    @map("loans_target")
  parLastYear        Decimal   @map("par_lastyear") @db.Decimal
  parTarget          Decimal   @map("par_target") @db.Decimal
  profitLastYear     BigInt    @map("profit_lastyear")
  profitTarget       BigInt    @map("profit_target")
  savingRateLastYear Decimal   @map("savingrate_lastyear") @db.Decimal
  savingRateTarget   Decimal?  @map("savingrate_target") @db.Decimal
  vbCode             String    @map("vbcode") @db.Char(7)
  synchronized       DateTime? @db.Timestamp(6)
  needSync           String?   @map("need_sync") @db.Char(1)
  startDate          DateTime? @map("start_date") @db.Date
  endDate            DateTime? @map("end_date") @db.Date
  vb                 VbCode    @relation(fields: [vbCode], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_2170")

  @@id([businessYear, vbCode], map: "PK_vb_targets")
  @@index([vbCode], map: "fkIdx_2170")
  @@map("vb_targets")
}

model VbServiceDays {
  id                Int       @default(autoincrement())
  serviceDayPlanned DateTime  @map("serviceday_planned") @db.Date
  startDateTime     DateTime  @map("start_date_time") @db.Timestamp(6)
  endDateTime       DateTime? @map("end_date_time") @db.Timestamp(6)
  comment           String?   @db.VarChar
  vbCode            String    @map("vbcode") @db.Char(7)
  nsoEmployeeId     String    @map("nso_employee_id") @db.Char(6)
  synchronized      DateTime? @db.Timestamp(6)
  needSync          String?   @map("need_sync") @db.Char(1)
  cashSw            BigInt?   @map("cash_sw")
  cashBox           BigInt?   @map("cash_box")
  cashBook          BigInt?   @map("cash_book")
  serviceDayEnd     String?   @map("service_day_end") @db.VarChar(10)
  closeMeeting      String?   @map("close_meeting") @db.VarChar(10)
  vb                VbCode    @relation(fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_889")

  @@id([id, vbCode], map: "vb_servicedays_pk")
  @@index([vbCode], map: "fkIdx_889")
  @@map("vb_servicedays")
}

model Client {
  id                     String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bankbookNumber         String?                 @map("bankbooknumber") @db.Char(5)
  firstName              String?                 @map("firstname") @db.VarChar
  lastName               String?                 @map("lastname") @db.VarChar
  nickName               String                  @map("nickname") @db.VarChar
  genderEng              String?                 @map("gender_eng") @db.VarChar(50)
  genderLao              String?                 @map("gender_lao") @db.VarChar
  birthDate              DateTime?               @map("birthdate") @db.Date
  clientType             String                  @map("client_type") @db.VarChar
  statusId               String                  @map("status_id") @db.Char(1)
  email                  String?                 @db.VarChar
  phoneNumber            String?                 @map("phonenumber") @db.Char(12)
  economicStatusId       String?                 @map("economic_status_id") @db.Char(1)
  professionId           String?                 @map("profession_id") @db.Char(2)
  beneficiaryLao         String?                 @map("beneficiary_lao") @db.VarChar
  vbCode                 String                  @map("vbcode") @db.Char(7)
  sortNo                 String?                 @map("sort_no") @db.Char(4)
  isGuarantor            String?                 @map("is_guarantor") @db.Char(1)
  guarantorVolume        Int?                    @map("guarantor_volume")
  synchronized           DateTime?               @db.Timestamp(6)
  needSync               String?                 @map("need_sync") @db.Char(1)
  civilStatusId          String?                 @map("civil_status_id") @db.Char(2)
  ethnicId               String?                 @map("ethnic_id") @db.Char(2)
  requestName            String?                 @map("request_name") @db.VarChar
  requestAccNumber       String?                 @map("request_acc_number") @db.VarChar
  accountOwners          AccountOwner[]
  profession             Profession?             @relation(fields: [professionId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_1454")
  economicStatus         EconomicStatus?         @relation(fields: [economicStatusId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "FK_1550")
  status                 Status                  @relation(fields: [statusId], references: [id], onUpdate: Restrict, map: "FK_1561")
  vb                     VbCode                  @relation(fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_870")
  clientLoanArrangements ClientLoanArrangement[]
  idDocuments            IdDocument[]
  profitDistrVbcs        ProfitDistrVbc[]
  vbCommitteeTeams       VbCommitteeTeam[]

  @@index([professionId], map: "fkIdx_1454")
  @@index([economicStatusId], map: "fkIdx_1550")
  @@index([statusId], map: "fkIdx_1561")
  @@index([vbCode], map: "fkIdx_870")
  @@map("client")
}

model ClientAccount {
  bankbookNumber String         @map("bankbooknumber") @db.VarChar(5)
  vbCode         String         @map("vbcode") @db.VarChar(7)
  username       String         @unique @db.VarChar(50)
  phoneNumber    String?        @map("phone_number") @db.VarChar(12)
  password       String
  vb             VbCode         @relation(fields: [vbCode], references: [id], onDelete: NoAction, onUpdate: NoAction)
  refreshTokens  RefreshToken[]
  clientNotifications ClientMeetingNotification[]
  deviceFcm      DeviceFcm[]

  @@id([bankbookNumber, vbCode])
  @@map("client_account")
}

model DeviceFcm {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId          String   @map("device_id") @db.VarChar(255)
  fcmToken          String?  @map("fcm_token") @db.Text
  fcmTokenUpdatedAt DateTime? @map("fcm_token_updated_at") @db.Timestamp(6)
  username          String   @db.VarChar(50)
  isActive          Boolean  @default(true) @map("is_active")
  clientAccount     ClientAccount @relation(fields: [username], references: [username], onDelete: Cascade)

  @@unique([username, deviceId])
  @@map("devices_fcm")
}

model RefreshToken {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bankbookNumber String        @map("bankbooknumber") @db.VarChar(5)
  vbCode         String        @map("vbcode") @db.VarChar(7)
  token          String        @unique
  expiresAt      DateTime      @map("expires_at") @db.Timestamp(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  revokedAt      DateTime?     @map("revoked_at") @db.Timestamp(6)
  isRevoked      Boolean       @default(false) @map("is_revoked")
  ipAddress      String?       @map("ip_address") @db.VarChar(45)
  userAgent      String?       @map("user_agent")
  clientAccount  ClientAccount @relation(fields: [bankbookNumber, vbCode], references: [bankbookNumber, vbCode], onDelete: Cascade, onUpdate: NoAction)

  @@index([bankbookNumber])
  @@index([token])
  @@map("refresh_token")
}

model IdDocument {
  id                                BigInt    @default(autoincrement())
  documentNameLao                   String?   @map("document_name_lao") @db.VarChar
  documentNameEng                   String?   @map("document_name_eng") @db.VarChar
  iddocumentdate                    DateTime? @map("iddocumentdate") @db.Date
  idDocumentNumber                  String?   @map("iddocmentnumber") @db.VarChar
  fambookIndivNumber                String?   @map("fambook_indiv_number") @db.VarChar
  placeOfIssueEng                   String?   @map("place_of_issue_eng") @db.VarChar
  placeOfIssueLao                   String?   @map("place_of_isue_lao") @db.VarChar
  clientId                          String    @map("client_id") @db.Uuid
  sortNo                            Int?      @map("sort_no")
  vbCode                            String?   @map("vbcode") @db.Char(7)
  synchronized                      DateTime? @db.Timestamp(6)
  change                            String?   @db.Char(2)
  needSync                          String?   @map("need_sync") @db.Char(1)
  householdWorks                    String?   @map("household_works") @db.VarChar
  client                            Client     @relation(fields: [clientId], references: [id], onUpdate: Restrict, map: "FK_1157")
  vbcode_id_document_vbcodeTovbcode VbCode?    @relation("id_document_vbcodeTovbcode", fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_2069")

  @@id([id], map: "id_document_pk")
  @@index([clientId], map: "fkIdx_1157")
  @@index([vbCode], map: "fkIdx_2069")
  @@map("id_document")
}

model AccountOwner {
  bankbookNumber String    @map("bankbooknumber") @db.Char(5)
  accNumber      String    @map("acc_number") @db.Char(15)
  clientId       String    @map("client_id") @db.Uuid
  synchronized   DateTime? @db.Timestamp(6)
  needSync       String?   @map("need_sync") @db.Char(1)
  vbCode         String    @map("vbcode") @db.Char(7)
  account        Accounts  @relation(fields: [accNumber], references: [accNumber], onUpdate: Restrict, map: "FK_1074")
  client         Client    @relation(fields: [clientId], references: [id], onUpdate: Restrict, map: "FK_1080")
  vb             VbCode    @relation(fields: [vbCode], references: [id], onUpdate: Restrict, map: "FK_2221")

  @@id([bankbookNumber, accNumber, clientId])
  @@index([accNumber], map: "fkIdx_1074")
